# PermitFlow — Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and should never be committed.

# ── Claude AI (see docs/CLAUDE_INTEGRATION.md) ─────────────
# Leave blank to use mock data (demo/dev mode — no API calls made)
VITE_CLAUDE_API_KEY=

# Model: claude-sonnet-4-6 | claude-opus-4-6 | claude-haiku-4-5-20251001
VITE_CLAUDE_MODEL=claude-sonnet-4-6

# Override to point at a self-hosted ECS proxy (see CLAUDE_INTEGRATION.md)
VITE_CLAUDE_BASE_URL=https://api.anthropic.com

# ── Supabase (when backend is wired up) ────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
